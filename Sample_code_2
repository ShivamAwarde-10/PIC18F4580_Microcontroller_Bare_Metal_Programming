#include <xc.h>

#include "password.h"
#include "matrix_keypad.h"
#include "clcd.h"
#include "timer0.h"

static const unsigned char correct_password[PASSWORD_LENGTH] =
{
    PASSWORD_KEY1,
    PASSWORD_KEY2,
    PASSWORD_KEY1,
    PASSWORD_KEY2,
    PASSWORD_KEY1,
    PASSWORD_KEY2,
    PASSWORD_KEY1,
    PASSWORD_KEY2
};

static unsigned char entered_password[PASSWORD_LENGTH];

static unsigned char index = 0;

unsigned char attempts = 0;

static unsigned char cursor = 1;

static unsigned char blink = 1;

void init_password(void)
{
    index = 0;
    attempts = 0;

    cursor = 1;
}

void display_password_screen(void)
{
    unsigned char i;

    clcd_print("ENTER PASSWORD", LINE1(1));

    if(blink_flag)
    {
        blink_flag = 0;

        blink = !blink;
    }

    for(i = 0 ; i < index ; i++)
    {
        clcd_putch('*', LINE2(i));
    }

    if(index < PASSWORD_LENGTH)
    {
        if(blink)
            clcd_putch('_', LINE2(index));
        else
            clcd_putch(' ', LINE2(index));
    }
}

unsigned char password_task(void)
{
    unsigned char key;

    key = read_switches(STATE_CHANGE);

    if(key == PASSWORD_KEY1 || key == PASSWORD_KEY2)
    {
        entered_password[index++] = key;

        while(read_switches(LEVEL_CHANGE) != ALL_RELEASED);

        if(index >= PASSWORD_LENGTH)
        {
            unsigned char i;

            for(i = 0 ; i < PASSWORD_LENGTH ; i++)
            {
                if(entered_password[i] != correct_password[i])
                {
                    attempts++;

                    index = 0;

                    return PASSWORD_FAIL;
                }
            }

            return PASSWORD_SUCCESS;
        }
    }

    return PASSWORD_INCOMPLETE;
}

void display_success(void)
{
    clcd_write(0x01,0);

    clcd_print(" PASSWORD OK ",LINE1(1));

    clcd_print("ACCESS GRANTED",LINE2(1));
}

void display_failure(void)
{
    clcd_write(0x01,0);

    clcd_print("ACCESS DENIED",LINE1(1));

    clcd_print(" RESET BOARD ",LINE2(1));
}

void led_task(void)
{
    static unsigned int count = 0;

    unsigned int delay;

    if(attempts==0)
        return;

    if(attempts==1)
        delay=600;

    else if(attempts==2)
        delay=300;

    else if(attempts==3)
        delay=150;

    else if(attempts==4)
        delay=75;

    else
    {
        RB0=1;
        return;
    }

    if(led_flag)
    {
        led_flag=0;

        if(++count>=delay)
        {
            count=0;

            RB0=!RB0;
        }
    }
}

