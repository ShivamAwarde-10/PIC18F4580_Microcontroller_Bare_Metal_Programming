    /* CLCD */
    init_clcd();

    /* Matrix Keypad */
    init_matrix_keypad();

    /* Timer0 */
    init_timer0();

    /* LED */
    TRISB0 = 0;
    RB0 = 0;

    /* Interrupts */
    GIE = 1;
    PEIE = 1;
}

