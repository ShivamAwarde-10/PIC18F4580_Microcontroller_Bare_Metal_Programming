#include <xc.h>
#include "timer0.h"

volatile unsigned char blink_flag = 0;
volatile unsigned char led_flag = 0;

void init_timer0(void)
{
    /* Timer0 8-bit */
    T08BIT = 1;

    /* Internal Clock */
    T0CS = 0;

    /* No Prescaler */
    PSA = 1;

    /* Preload */
    TMR0 = 6;

    TMR0IF = 0;
    TMR0IE = 1;

    TMR0ON = 1;
}

void __interrupt() isr(void)
{
    static unsigned long blink_count = 0;
    static unsigned long led_count = 0;

    if(TMR0IF)
    {
        TMR0 += 8;

        /* 500ms Blink */
        if(++blink_count >= 20000)
        {
            blink_flag = 1;
            blink_count = 0;
        }

        /* LED timing base */
        if(++led_count >= 1000)
        {
            led_flag = 1;
            led_count = 0;
        }

        TMR0IF = 0;
    }
}

